# Twitter/X 认证配置
TWITTER_AUTH_TOKEN=your_twitter_auth_token

# 代理配置（可选，留空则不使用代理）
PROXY_URI=http://127.0.0.1:10808

# MongoDB 配置
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=getmyx
MONGODB_COLLECTION=items
MEDIA_COLLECTION_NAME=media

# 媒体文件配置
MEDIA_DOWNLOAD_DIR=./downloads
MEDIA_THUMBNAIL_DIR=./thumbnails
MEDIA_THUMBNAIL_WIDTH=720

# 过滤关键词配置（英文逗号分隔，不区分大小写）
FILTER_KEYWORDS=keyword1,keyword2,keyword3

# 定时任务配置（CRON 表达式）
# 默认：每 30 分钟执行一次
CRON_SCHEDULE=*/30 * * * *

# Matrix Bot 配置（可选，不配置则不启用 Matrix 功能）
MATRIX_HOMESERVER=https://matrix.org
MATRIX_USER_ID=@your_user:matrix.org
MATRIX_ACCESS_TOKEN=your_access_token
MATRIX_ROOM_ID=!your_room_id:matrix.org
# 大文件房间配置（可选，用于分流大文件）
MATRIX_LARGE_FILE_ROOM_ID=!your_large_room_id:matrix.org
MATRIX_LARGE_FILE_THRESHOLD_MB=50  # 文件大小阈值(MB)，超过此大小发送到大型文件房间，设为0或不配置则不启用分流
MATRIX_SEND_INTERVAL_MS=1000  # 发送间隔(毫秒)，避免发送过快被限流

